# === Core Telegram ===
# Either export BOT_TOKEN directly or point at a file.
# BOT_TOKEN=
BOT_TOKEN_FILE=/run/secrets/bot_token
BOT_USERNAME=commodore_lev_bot

# === Channel / topic IDs ===
# Prefix forum channels with -100.
BOT_HQ_GROUP_ID=
SQUID_CAVE_GROUP_ID=
AGENT_CHAT_GROUP_ID=-1003675648747

# Agent Chat forum topic overrides (defaults mirror squid-bot
# leviathan/settings.py::AGENT_CHAT_TOPICS).
# AGENT_CHAT_TOPIC_START_HERE=154
# AGENT_CHAT_TOPIC_MONETIZATION=155
# AGENT_CHAT_TOPIC_SANDBOX=156
# AGENT_CHAT_TOPIC_OPSEC=157
# AGENT_CHAT_TOPIC_API_HELP=158
# AGENT_CHAT_TOPIC_HUMAN_LOUNGE=159
# AGENT_CHAT_TOPIC_AFFILIATE=1709

# === Authorization ===
# Telegram user_ids authorized to order draft PR filing.
# CurveCap (1234982301) is the default operator; extend as needed.
ADMIN_TELEGRAM_IDS=1234982301

# === Leviathan News API (Mode B relay receipt) ===
LN_API_BASE=https://api.leviathannews.xyz/api/v1
LN_API_TOKEN=

# === LLM provider ===
# CLAUDE_BIN=  # auto-detected
# CODEX_BIN=   # auto-detected
CODEX_MODEL=gpt-5.4
CLAUDE_LIMIT_COOLDOWN=21600

# === GitHub identity ===
# Path to PAT file for leviathan-commodore GitHub user.
GH_PAT_FILE=/run/secrets/gh_pat
GIT_AUTHOR_NAME=Leviathan Commodore
GIT_AUTHOR_EMAIL=commodore@leviathan.ops
GIT_COMMITTER_NAME=Leviathan Commodore
GIT_COMMITTER_EMAIL=commodore@leviathan.ops

# NOTE: The server-side wager denylist AGENT_WAGER_DENYLIST lives on the
# squid-bot side (leviathan/settings.py + .env), NOT here. After the
# Commodore bot is registered on Telegram, look up its bot user_id via
# getMe and add that int to AGENT_WAGER_DENYLIST in the squid-bot prod env.
